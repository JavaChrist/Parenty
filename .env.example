# Template des variables d'environnement — committé sur Git, SANS valeurs réelles.
# Copie ce fichier en .env.local et remplis avec tes vraies clés.
#
# Comment obtenir les valeurs :
#  - VITE_SUPABASE_URL       : Dashboard Supabase > Project Settings > API > Project URL
#  - VITE_SUPABASE_ANON_KEY  : Dashboard Supabase > Project Settings > API > Project API keys > anon / publishable
#
# Ne jamais mettre la clé service_role ici (ni ailleurs côté client).

# Supabase
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=sb_publishable_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# App
VITE_APP_URL=http://localhost:5173
